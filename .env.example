# .env.example
# ─────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in REAL values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────
APP_ENV=development                        # development | staging | production
APP_VERSION=1.0.0
ENABLE_SCHEDULER=false                     # true only in production worker

# ── Database ─────────────────────────────────────────────────────
DB_TYPE=postgres                           # postgres | sqlite
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_ECHO_POOL=false
DB_SSL_VERIFY=true                         # set false ONLY for local dev with self-signed certs

# ── Auth / JWT ───────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_ACCESS_SECRET_KEY=REPLACE_WITH_STRONG_SECRET
ACCESS_TOKEN_EXPIRE_MINUTES=15
ADMIN_ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── GST ──────────────────────────────────────────────────────────
GST_RATE=0.18                              # 18% standard rate

# ── CORS ─────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── File Uploads ─────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# ── Inventory ────────────────────────────────────────────────────
DEFAULT_WAREHOUSE_LOCATION_ID=1

# ── Company Branding (used in PDF generation) ─────────────────────
COMPANY_NAME=Varasidhi Furnitures
COMPANY_GSTIN=YOUR_GSTIN_HERE
COMPANY_ADDRESS_LINE1=No. 1, Main Road
COMPANY_ADDRESS_LINE2=Bengaluru, Karnataka - 560001
COMPANY_PHONE=+91 XXXXX XXXXX
COMPANY_EMAIL=billing@yourdomain.com
