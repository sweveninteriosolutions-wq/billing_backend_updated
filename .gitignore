# ─── Python ──────────────────────────────────────────────────────────────────
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
*.pyc.*
*.pyo.*
*.egg-info/
*.egg
*.so
dist/
build/

# ─── Virtual environments ─────────────────────────────────────────────────────
.venv
venv/
env/
sweven/

# ─── Environment / Secrets — NEVER COMMIT THESE ──────────────────────────────
# ERP-001 / ERP-054: .env must never be committed.
# If you accidentally committed it, run:
#   git rm --cached .env
#   git filter-repo --path .env --invert-paths   (or git filter-branch)
#   Immediately rotate all secrets in the committed file.
.env
.env.*
!.env.example

# ─── Alembic (generated migration files stay, ini stays tracked) ──────────────
# alembic/versions/ — keep tracked
# alembic.ini — keep tracked

# ─── IDE / Editor ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── OS ──────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
logs/

# ─── Databases ───────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ─── Uploads / generated files ───────────────────────────────────────────────
uploads/
generated_pdfs/

# ─── Test / Coverage ─────────────────────────────────────────────────────────
